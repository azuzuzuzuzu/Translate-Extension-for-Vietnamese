{
  "manifest_version": 3,
  "name": "Translate Selection",
  "version": "2.1.0",
  "description": "Dịch văn bản được chọn trên bất kỳ trang web nào. Hỗ trợ kéo cửa sổ, dark/light mode.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://translate.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Translate Selection\n\n⌨ Ctrl+Shift+T: Dịch nhanh",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
